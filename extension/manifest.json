{
  "manifest_version": 2,
  "name": "Browser Bridge for Claude Code",
  "version": "0.1.0",
  "description": "Bridges Firefox to Claude Code via MCP — captures network traffic and enables DOM queries.",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Browser Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "browser-bridge@claude-code",
      "strict_min_version": "109.0"
    }
  }
}
